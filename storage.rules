rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Permite que cualquiera suba imágenes de referencia para cotizaciones,
    // pero solo permite leerlas/borrarlas a administradoras autenticadas.
    match /custom_orders/{allPaths=**} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    // Permite que las administradoras autenticadas suban imágenes del catálogo,
    // y que todo el mundo pueda verlas (lectura pública).
    match /designs/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
